{
  "name": "homebridge-palgate",
  "description": "Homebridge plugin for PalGate App",
  "version": "3.5.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Knilo/homebridge-palgate.git"
  },
  "license": "MIT",
  "keywords": [
    "homebridge-plugin",
    "homebridge-palgate",
    "homebridge-palgate-platform"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0",
    "homebridge": "^1.9.0 || ^2.0.0-beta.0"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.0.1",
    "axios": "^1.17.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^14.0.0"
  },
  "main": "index.js",
  "scripts": {
    "test": "node --test test/unit/*.test.js test/api/*.test.js test/platform/*.test.js test/ui-server/*.test.js",
    "test:e2e": "node test/e2e/plugin-ui.e2e.js",
    "test:e2e:restart": "E2E_RESTART=1 node test/e2e/plugin-ui.e2e.js",
    "deploy:local": "npm link && sudo hb-service restart",
    "config": "palgate-cli config --auto && sudo hb-service restart"
  },
  "author": "@Knilo",
  "funding": {
    "type": "kofi",
    "url": "https://ko-fi.com/knilo"
  },
  "bugs": {
    "url": "https://github.com/Knilo/homebridge-palgate/issues"
  },
  "bin": {
    "palgate-cli": "./cli/palgate-cli.js"
  },
  "homepage": "https://github.com/Knilo/homebridge-palgate#readme",
  "directories": {
    "lib": "lib",
    "bin": "cli"
  },
  "devDependencies": {
    "homebridge-config-ui-x": "^5.24.0",
    "puppeteer-core": "^25.3.0"
  }
}
